<NotepadPlus>
    <!--
        SLIM — Structured LLM Instruction Markup
        Notepad++ User Defined Language v1.0

        INSTALL:
          1. Open Notepad++
          2. Language > User Defined Language > Define Your Language...
          3. Click "Import..." and select this file
          4. Restart Notepad++
          5. .slm files will auto-highlight
    -->
    <UserLang name="SLIM" ext="slm" udlVersion="2.1">
        <Settings>
            <Global caseIgnored="no" allowFoldOfComments="no" foldCompact="no" forcePureLC="0" decimalSeparator="0" />
            <Prefix Keywords1="no" Keywords2="no" Keywords3="no" Keywords4="no" Keywords5="yes" Keywords6="no" Keywords7="no" Keywords8="no" />
        </Settings>
        <KeywordLists>
            <!-- Line comment: ~ -->
            <Keywords name="Comments">01~ 00 00 00</Keywords>
            <Keywords name="Numbers, prefix1"></Keywords>
            <Keywords name="Numbers, prefix2"></Keywords>
            <Keywords name="Numbers, extras1"></Keywords>
            <Keywords name="Numbers, extras2"></Keywords>
            <Keywords name="Numbers, suffix1"></Keywords>
            <Keywords name="Numbers, suffix2"></Keywords>
            <Keywords name="Numbers, range">0 9</Keywords>
            <!-- Operators -->
            <Keywords name="Operators1">@ $ &gt;</Keywords>
            <Keywords name="Operators2">: !</Keywords>
            <!-- Block folds on === NAME / === /NAME -->
            <Keywords name="Folders in code1, open">=== </Keywords>
            <Keywords name="Folders in code1, middle"></Keywords>
            <Keywords name="Folders in code1, close">=== /</Keywords>
            <Keywords name="Folders in code2, open"></Keywords>
            <Keywords name="Folders in code2, middle"></Keywords>
            <Keywords name="Folders in code2, close"></Keywords>
            <Keywords name="Folders in comment, open"></Keywords>
            <Keywords name="Folders in comment, middle"></Keywords>
            <Keywords name="Folders in comment, close"></Keywords>
            <!-- Keywords1: directive keywords -->
            <Keywords name="Keywords1">CALL ASSERT YIELD EMIT LOG ABORT WAIT RETRY</Keywords>
            <!-- Keywords2: reserved header keys -->
            <Keywords name="Keywords2">slim model agent task retry timeout tags include version mode</Keywords>
            <!-- Keywords3: SLIM type names -->
            <Keywords name="Keywords3">str int float bool null none true false datetime url uuid json list dict</Keywords>
            <!-- Keywords4: schema punctuation helpers -->
            <Keywords name="Keywords4"></Keywords>
            <!-- Keywords5: block names (uppercase) — prefix match on === -->
            <Keywords name="Keywords5">CODE CONTEXT SCHEMA PROMPT SYSTEM USER ASSISTANT DATA CONFIG RULES OUTPUT INPUT BLOCK</Keywords>
            <Keywords name="Keywords6"></Keywords>
            <Keywords name="Keywords7"></Keywords>
            <Keywords name="Keywords8"></Keywords>
        </KeywordLists>
        <Styles>
            <!-- DEFAULT text -->
            <WordsStyle name="DEFAULT"         fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <!-- ~ comments: green italic -->
            <WordsStyle name="COMMENTS"        fgColor="6A9955" bgColor="1E1E1E" fontName="" fontStyle="2" nesting="0" />
            <WordsStyle name="LINE COMMENTS"   fgColor="6A9955" bgColor="1E1E1E" fontName="" fontStyle="2" nesting="0" />
            <!-- Numbers -->
            <WordsStyle name="NUMBERS"         fgColor="B5CEA8" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <!-- CALL ASSERT YIELD etc: yellow bold -->
            <WordsStyle name="KEYWORDS1"       fgColor="DCDCAA" bgColor="1E1E1E" fontName="" fontStyle="1" nesting="0" />
            <!-- Reserved header keys: blue -->
            <WordsStyle name="KEYWORDS2"       fgColor="569CD6" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <!-- Type names: teal -->
            <WordsStyle name="KEYWORDS3"       fgColor="4EC9B0" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS4"       fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <!-- Block names inside === -->
            <WordsStyle name="KEYWORDS5"       fgColor="C586C0" bgColor="1E1E1E" fontName="" fontStyle="1" nesting="0" />
            <WordsStyle name="KEYWORDS6"       fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS7"       fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="KEYWORDS8"       fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <!-- @ $ > : sigils: teal bold -->
            <WordsStyle name="OPERATORS"       fgColor="1B7F79" bgColor="1E1E1E" fontName="" fontStyle="1" nesting="0" />
            <!-- === block fold markers: purple bold -->
            <WordsStyle name="FOLDER IN CODE1" fgColor="C586C0" bgColor="1E1E1E" fontName="" fontStyle="1" nesting="0" />
            <WordsStyle name="FOLDER IN CODE2" fgColor="C586C0" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="FOLDER IN COMMENT" fgColor="C586C0" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <!-- Delimiter1: [ ] for type tags — orange -->
            <WordsStyle name="DELIMITERS1"     fgColor="CE9178" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS2"     fgColor="CE9178" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS3"     fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS4"     fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS5"     fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS6"     fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS7"     fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
            <WordsStyle name="DELIMITERS8"     fgColor="D4D4D4" bgColor="1E1E1E" fontName="" fontStyle="0" nesting="0" />
        </Styles>
    </UserLang>
</NotepadPlus>
